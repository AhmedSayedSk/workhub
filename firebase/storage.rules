rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidSize() {
      return request.resource.size <= 50 * 1024 * 1024;
    }

    // Media files
    match /media/{userId}/{allPaths=**} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow write: if isAuthenticated() && isOwner(userId) && isValidSize();
    }

    // Voice comment audio files
    match /comments/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isOwner(userId) && isValidSize();
    }

    // Calendar event images
    match /calendar-events/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isOwner(userId) && isValidSize();
    }

    // AI asset thumbnails (reference images)
    match /ai-assets/{userId}/{allPaths=**} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create, update: if isAuthenticated() && isOwner(userId) && isValidSize();
      allow delete: if isAuthenticated() && isOwner(userId);
    }

    // AI generated images
    match /ai-images/{userId}/{allPaths=**} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create, update: if isAuthenticated() && isOwner(userId) && isValidSize();
      allow delete: if isAuthenticated() && isOwner(userId);
    }
  }
}
