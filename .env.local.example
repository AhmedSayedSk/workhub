# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Web Search: Uses DuckDuckGo (free, no API key required, unlimited searches)

# Firebase Admin SDK (for migrations only)
# Download from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Save the file as "firebase-service-account.json" in the project root (it is gitignored)

# ZeptoMail (Zoho's transactional email service) — for email notifications
# 1. Sign in at https://www.zoho.com/zeptomail/ with your Zoho account
# 2. Verify your sending domain (e.g., sikasio.com)
# 3. Generate an API key under Mail Agents → SMTP & API
# 4. Username is literally `emailapikey` (not your Zoho username); password is the API key
ZOHO_MAIL_HOST=smtp.zeptomail.com
ZOHO_MAIL_PORT=465
ZOHO_MAIL_USER=emailapikey
ZOHO_MAIL_PASS=your_zeptomail_api_key
ZOHO_MAIL_FROM=WorkHub <workhub@sikasio.com>

# HTTP transport (REQUIRED in production on platforms that block SMTP egress —
# Railway, Vercel, Cloud Run, Fly free, etc. all block ports 25/465/587).
# When set, the app sends via ZeptoMail's HTTPS API instead of SMTP, reusing
# ZOHO_MAIL_PASS as the Authorization header. Leave commented out for local
# dev to keep using SMTP. US data center: api.zeptomail.com · EU: api.zeptomail.eu
# ZOHO_MAIL_API_URL=https://api.zeptomail.com/v1.1/email

# Used in email links (production domain — keep as-is so emails always link to live site)
NEXT_PUBLIC_APP_URL=https://workhub.sikasio.com

# Optional: address shown in the email "unsubscribe / contact admin" footer.
# Falls back to the bare email inside ZOHO_MAIL_FROM when unset.
# ADMIN_CONTACT_EMAIL=workhub@sikasio.com

# Shared secret used by the MCP server (or other internal callers) to authenticate
# against /api/email/notify without a Firebase user JWT. Generate with:
#   openssl rand -hex 32
INTERNAL_API_TOKEN=
